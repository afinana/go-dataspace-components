# Terraform Environment Variables
# Copy this file to .env and modify the values for your setup:
#   cp env.example .env
#
# To load these environment variables prior to running Terraform:
#   export $(grep -v '^#' .env | xargs)

# Path to the kubeconfig file for cluster connection
TF_VAR_kubeconfig_path="~/.kube/config"

# Context to use in the kubeconfig file
TF_VAR_kubeconfig_context="default"

# Kubernetes namespace to deploy resources into
TF_VAR_namespace="sovereign-dataspace"

# Password for the Postgres database
TF_VAR_postgres_password="postgres-secure-password"

# Docker image tag for all services
TF_VAR_image_tag="latest"
